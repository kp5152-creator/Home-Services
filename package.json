{
  "name": "desert-home-watch-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:demo": "next dev --hostname 0.0.0.0 --port 3030",
    "dev:clean": "rm -rf .next && next dev --hostname 0.0.0.0 --port 3030",
    "build": "next build",
    "build:check": "rm -rf .next-build-check && NEXT_DIST_DIR=.next-build-check next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "demo:check": "node scripts/check-local-demo.mjs",
    "verify": "npm run build:check && npm run typecheck"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.1",
    "@types/pdfkit": "^0.17.6",
    "next": "^15.5.18",
    "pdfkit": "^0.18.0",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "overrides": {
    "postcss": "8.5.15"
  },
  "devDependencies": {
    "@next/swc-wasm-nodejs": "^15.5.18",
    "@types/node": "22.15.19",
    "@types/react": "19.0.12",
    "@types/react-dom": "19.0.4",
    "autoprefixer": "10.4.21",
    "postcss": "8.5.15",
    "tailwindcss": "3.4.17",
    "typescript": "5.8.3"
  }
}
